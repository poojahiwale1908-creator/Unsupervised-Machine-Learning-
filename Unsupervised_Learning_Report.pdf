13. CODE APPENDIX
======================================================================

The following Python code was used for this analysis:

# Import Libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans, AgglomerativeClustering, DBSCAN
from sklearn.decomposition import PCA
from sklearn.metrics import silhouette_score, calinski_harabasz_score, davies_bouldin_score
from scipy.cluster.hierarchy import dendrogram, linkage
import warnings
warnings.filterwarnings('ignore')

# Set style
sns.set_style("whitegrid")
plt.rcParams['figure.figsize'] = (12, 8)

print("✅ All libraries imported successfully!")

# Generate Synthetic Data
np.random.seed(42)
n_customers = 200

age = np.random.randint(18, 70, n_customers)
income = np.random.normal(60, 25, n_customers)
income = np.clip(income, 15, 140)
spending = np.random.normal(50, 25, n_customers)
spending = np.clip(spending, 1, 99)

for i in range(n_customers):
    if income[i] > 80:
        spending[i] = np.random.normal(75, 15, 1)[0]
    elif income[i] > 50:
        spending[i] = np.random.normal(50, 20, 1)[0]
    else:
        spending[i] = np.random.normal(30, 15, 1)[0]
    spending[i] = np.clip(spending[i], 1, 99)

gender = np.random.choice(['Male', 'Female'], n_customers, p=[0.4, 0.6])

df = pd.DataFrame({
    'CustomerID': range(1, n_customers + 1),
    'Gender': gender,
    'Age': age.astype(int),
    'Annual Income (k$)': income.astype(int),
    'Spending Score (1-100)': spending.astype(int)
})

# Data Preprocessing
features = ['Age', 'Annual Income (k$)', 'Spending Score (1-100)']
X = df[features].copy()
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# Find Optimal K for K-Means
inertias = []
silhouettes = []
K_range = range(2, 11)

for k in K_range:
    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
    kmeans.fit(X_scaled)
    inertias.append(kmeans.inertia_)
    silhouettes.append(silhouette_score(X_scaled, kmeans.labels_))

best_k = K_range[np.argmax(silhouettes)]

# Train K-Means Models
k_values = [3, 4, 5]
kmeans_metrics = []
kmeans_models = {}

for k in k_values:
    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = kmeans.fit_predict(X_scaled)
    kmeans_models[k] = kmeans
    
    sil = silhouette_score(X_scaled, labels)
    ch = calinski_harabasz_score(X_scaled, labels)
    db = davies_bouldin_score(X_scaled, labels)
    
    kmeans_metrics.append({
        'Model': f'K-Means (K={k})',
        'Silhouette': round(sil, 4),
        'Calinski-Harabasz': round(ch, 2),
        'Davies-Bouldin': round(db, 4)
    })

# Train Hierarchical Models
linkage_methods = ['single', 'complete', 'ward']
hierarchical_metrics = []
hierarchical_models = {}

for method in linkage_methods:
    hier = AgglomerativeClustering(n_clusters=best_k, linkage=method)
    labels = hier.fit_predict(X_scaled)
    hierarchical_models[method] = hier
    
    sil = silhouette_score(X_scaled, labels)
    ch = calinski_harabasz_score(X_scaled, labels)
    db = davies_bouldin_score(X_scaled, labels)
    
    hierarchical_metrics.append({
        'Model': f'Hierarchical ({method})',
        'Silhouette': round(sil, 4),
        'Calinski-Harabasz': round(ch, 2),
        'Davies-Bouldin': round(db, 4)
    })

# Train DBSCAN Models
eps_values = [0.3, 0.5, 0.7]
dbscan_metrics = []
dbscan_models = {}

for eps in eps_values:
    dbscan = DBSCAN(eps=eps, min_samples=5)
    labels = dbscan.fit_predict(X_scaled)
    dbscan_models[eps] = dbscan
    
    n_clusters = len(set(labels)) - (1 if -1 in labels else 0)
    n_noise = list(labels).count(-1)
    
    if n_clusters > 1:
        sil = silhouette_score(X_scaled, labels)
        ch = calinski_harabasz_score(X_scaled, labels)
        db = davies_bouldin_score(X_scaled, labels)
    else:
        sil = 0
        ch = 0
        db = 0
    
    dbscan_metrics.append({
        'Model': f'DBSCAN (eps={eps})',
        'Clusters': n_clusters,
        'Noise Points': n_noise,
        'Silhouette': round(sil, 4),
        'Calinski-Harabasz': round(ch, 2),
        'Davies-Bouldin': round(db, 4)
    })

# Compare All Models
all_metrics = kmeans_metrics + hierarchical_metrics + dbscan_metrics
comparison_df = pd.DataFrame(all_metrics)

# Find Best Model
best_idx = comparison_df['Silhouette'].idxmax()
best_model = comparison_df.loc[best_idx, 'Model']
best_sil = comparison_df.loc[best_idx, 'Silhouette']

# Select Best Model
if 'K-Means' in best_model:
    k = int(best_model.split('K=')[1])
    best_model_obj = kmeans_models[k]
    labels = best_model_obj.labels_
elif 'Hierarchical' in best_model:
    method = best_model.split('(')[1].split(')')[0]
    best_model_obj = hierarchical_models[method]
    labels = best_model_obj.labels_
else:
    eps = float(best_model.split('eps=')[1].split(')')[0])
    best_model_obj = dbscan_models[eps]
    labels = best_model_obj.labels_

df['Cluster'] = labels

# Final Summary
print("="*60)
print("FINAL SUMMARY AND CONCLUSIONS")
print("="*60)

print("\n📊 MODEL PERFORMANCE SUMMARY:")
print(comparison_df.to_string(index=False))

print(f"\n🏆 BEST MODEL: {best_model}")
print(f"   Silhouette Score: {best_sil:.4f}")

print("\n🔍 KEY INSIGHTS:")

cluster_types = []
for cluster in sorted(df['Cluster'].unique()):
    cluster_data = df[df['Cluster'] == cluster]
    avg_income = cluster_data['Annual Income (k$)'].mean()
    avg_spending = cluster_data['Spending Score (1-100)'].mean()
    
    if avg_income > 70 and avg_spending > 60:
        cluster_types.append(f"   - Cluster {cluster}: High-Value Customers (Premium)")
    elif avg_income > 70 and avg_spending <= 60:
        cluster_types.append(f"   - Cluster {cluster}: High-Income, Low-Spending (Untapped Potential)")
    elif avg_income <= 50 and avg_spending > 60:
        cluster_types.append(f"   - Cluster {cluster}: Value Seekers (High Engagement)")
    elif avg_income <= 50 and avg_spending <= 40:
        cluster_types.append(f"   - Cluster {cluster}: Low-Value (Needs Attention)")
    else:
        cluster_types.append(f"   - Cluster {cluster}: Mid-Tier Customers")

for ct in cluster_types:
    print(ct)

print("\n💡 RECOMMENDATIONS:")
print("   1. Target High-Value customers with premium products")
print("   2. Convert High-Income, Low-Spending customers with special offers")
print("   3. Engage Value Seekers with loyalty programs")
print("   4. Focus retention strategies for Low-Value segment")

print("\n⚠️ LIMITATIONS:")
print("   1. Limited dataset (200 customers)")
print("   2. Only 3 features used for clustering")
print("   3. No temporal data (purchase history)")
print("   4. Synthetic data (not real customer data)")

print("\n🚀 FUTURE IMPROVEMENTS:")
print("   1. Add more features (purchase frequency, product categories)")
print("   2. Use real customer data")
print("   3. Implement time-series clustering for purchase patterns")
print("   4. Test additional algorithms (Spectral, Mean-Shift)")
print("   5. Validate segments with business metrics")

